{
  "name": "kindle-exporter",
  "version": "1.0.0",
  "description": "Export Obsidian notes to Kindle via email",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/nodemailer": "^6.4.14",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "nodemailer": "^6.9.9"
  }
}
